# AirPosture Website — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Resend API key for sending transactional emails
# Sign up at https://resend.com to get your API key
RESEND_API_KEY=

# Resend Audience ID for the waitlist subscriber list
# Find this in your Resend dashboard → Audiences
RESEND_AUDIENCE_ID=
